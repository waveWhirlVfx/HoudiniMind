# HoudiniMind environment configuration
# Copy to `.env` and fill in values. `.env` is gitignored.

# --- Ollama (local model server) ---------------------------------------------
HM_OLLAMA_HOST=http://127.0.0.1:11434
HM_DEFAULT_MODEL=qwen2.5-coder:14b
HM_VISION_MODEL=llava:7b

# --- Agent runtime -----------------------------------------------------------
HM_CONTEXT_TOKENS=16384
HM_MAX_TOOL_TURNS=24
HM_LOG_LEVEL=INFO
HM_SESSION_DIR=~/HoudiniMind/sessions

# --- Safety flags ------------------------------------------------------------
# Keep these OFF unless you know what you're doing.
HM_ALLOW_FILESYSTEM_WRITES=false
HM_ALLOW_PYTHON_EXEC=false

# --- MCP bridge --------------------------------------------------------------
HM_MCP_HOST=127.0.0.1
HM_MCP_PORT=8765

# --- Optional API fallbacks --------------------------------------------------
# Leave blank for a fully local setup.
HM_ANTHROPIC_API_KEY=
HM_OPENAI_API_KEY=
